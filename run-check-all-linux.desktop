[Desktop Entry]
Type=Application
Name=HYDRA-MSG Check All
Comment=Open a terminal and run the full HYDRA-MSG release validation gate
Exec=sh -c "script_dir=$(dirname \"$1\"); cd \"$script_dir\" && HYDRA_CHECK_ALL_INSIDE_TERMINAL=1 ./run-check-all-linux.sh" sh %k
Terminal=true
Categories=Development;
